{
  "name": "@economicagents/indexer",
  "version": "0.2.0",
  "description": "Provider discovery index for AEP intent resolution - crawls ERC-8004, indexes capabilities and pricing",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/economicagents/AEP.git"
  },
  "bugs": "https://github.com/economicagents/AEP/issues",
  "homepage": "https://github.com/economicagents/AEP#readme",
  "keywords": [
    "aep",
    "agent",
    "erc-8004",
    "indexer",
    "intent-resolution"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aep-index": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "sync": "node dist/cli.js sync",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@economicagents/sdk": "workspace:*",
    "@economicagents/viem-rpc": "workspace:*",
    "commander": "^12.1.0",
    "pg": "^8.13.1",
    "viem": "^2.47.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.1.0",
    "sqlite-vec": "^0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/pg": "^8.11.10",
    "typescript": "^6.0.2",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "migrations"
  ]
}
