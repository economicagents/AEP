{
  "name": "aep",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "aep": "aep",
    "swap-for-usdc": "node scripts/swap-for-usdc.mjs",
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r run build",
    "test": "pnpm run test:contracts && pnpm run test:packages",
    "test:contracts": "cd contracts && forge test -vvv",
    "test:packages": "pnpm -r run test",
    "test:smoke": "pnpm --filter @aep/smoke-tests run test",
    "validate:testnet": "pnpm --filter @aep/smoke-tests run validate",
    "dev:web": "pnpm --filter @aep/web dev",
    "build:web": "pnpm --filter @aep/web build",
    "verify:npm-metadata": "node scripts/verify-npm-publish-metadata.mjs"
  },
  "devDependencies": {
    "aep-cli": "workspace:*",
    "viem": "^2.47.5"
  }
}
