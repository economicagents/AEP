# AEP Base Sepolia — copy to .env and fill values.
# Single .env at repo root. For forge: ln -sf ../.env contracts/.env
#
# SECURITY:
# - Never commit .env (it is gitignored). Rotate keys immediately if exposed.
# - Prefer Foundry keystore over PRIVATE_KEY (see below).
# - Use hardware wallet for production; .env is for dev/test only.
# - chmod 600 .env recommended.

# Signer (recommended: Foundry keystore)
# Import: cast wallet import aep --interactive
AEP_KEYSTORE_ACCOUNT=aep
# FOUNDRY_PASSWORD=...          # For non-interactive (CI)
# AEP_KEYSTORE_PATH=...         # Optional: full path to keystore file

# Fallback (insecure; prefer keystore above)
# PRIVATE_KEY=0x...             # Fallback; emits warning when used

# Deployer and treasury (address derived from signer above)
# When using keystore, address comes from cast wallet address --account aep

# Base Sepolia (forge uses base_sepolia from foundry.toml)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_RPC_FALLBACK=https://base-sepolia.drpc.org
BASE_SEPOLIA_EXPLORER_URL=https://sepolia.basescan.org
BASE_SEPOLIA_CHAIN_ID=84532

# Optional overrides
# AEP_TREASURY_ADDRESS=0x...   # Override treasury (default: address derived from signer)
# AEP_RPC_URL=...              # Override RPC for packages
# AEP_CHAIN_ID=84532           # Override chain ID
# AEP_CONFIG_PATH=...          # Override config path
# AEP_SILENCE_PRIVATE_KEY_WARNING=1  # Suppress PRIVATE_KEY warning (CI/legacy)
